    "tool_variants": [
      {
        "name": "docs_openwork_ui_mcp",
        "tools": [
          {
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_status",
            "purpose": "Check if OpenWork is running and reachable. Returns connection status and app info."
          },
          {
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_snapshot",
            "purpose": "Get current UI state: route, narration, visible actions, and status."
          },
          {
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_list_actions",
            "purpose": "List all UI control actions available. Each action id can be passed to ui_execute_action."
          },
          {
            "input_schema": {
              "properties": {
                "actionId": {
                  "type": "string"
                },
                "args": {
                  "additionalProperties": true,
                  "type": "object"
                }
              },
              "required": [
                "actionId"
              ],
              "type": "object"
            },
            "name": "ui_execute_action",
            "purpose": "Execute an OpenWork UI action by id."
          }
        ]
      },
      {
        "name": "source_tuned_openwork_ui_mcp",
        "tools": [
          {
            "avoid_when": "Avoid when the user needs the current route, visible actions, transcript, or screen state. Use ui_snapshot for current UI state.",
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_status",
            "purpose": "Check whether the OpenWork desktop app and local UI-control bridge are reachable.",
            "quality_checks": [
              "Use before trying to execute actions when the user says OpenWork may not be running."
            ],
            "use_when": "Use for connectivity checks, app-not-running uncertainty, or before diagnosing bridge errors."
          },
          {
            "avoid_when": "Avoid for a pure connectivity check. Avoid when the user already provided the exact action id and arguments to execute.",
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_snapshot",
            "purpose": "Read the current OpenWork route, narration, visible actions, busy status, and on-screen state.",
            "quality_checks": [
              "Start with a snapshot before acting on unknown UI state."
            ],
            "use_when": "Use before taking an action when the current UI state is unknown, when the user asks what screen they are on, or when you need visible action context."
          },
          {
            "avoid_when": "Avoid when the current screen state is the main unknown. Use ui_snapshot first for route and visible actions.",
            "input_schema": {
              "properties": {},
              "type": "object"
            },
            "name": "ui_list_actions",
            "purpose": "List executable semantic OpenWork UI actions, including action ids and required arguments.",
            "quality_checks": [
              "Use before ui_execute_action when action id or args are not known."
            ],
            "use_when": "Use when you need to discover valid action ids or required args before executing."
          },
          {
            "avoid_when": "Avoid for coordinate clicks, direct DOM operations, unknown action ids, unknown required args, or when OpenWork bridge reachability is unknown.",
            "input_schema": {
              "properties": {
                "actionId": {
                  "type": "string"
                },
                "args": {
                  "additionalProperties": true,
                  "type": "object"
                }
              },
              "required": [
                "actionId"
              ],
              "type": "object"
            },
            "name": "ui_execute_action",
            "purpose": "Execute a known semantic OpenWork UI action by id through the local bridge.",
            "quality_checks": [
              "Do not invent action ids.",
              "Use semantic actions rather than coordinate clicks.",
              "Check status first if the app may not be running."
            ],
            "use_when": "Use only when the action id is known from ui_list_actions or the user provided a valid action id, with required args available."
          }
        ]
      }
    ]
  },
