    "source": {
      "commit": "278bc96500d6b04a780fcf5ca04d190ab6adb85b",
      "package": "humwork-mcp",
      "package_version": "1.1.1",
      "repo": "https://github.com/humworkai/humwork-mcp",
      "slice": "expert consultation, active chat lifecycle, closure, rating, and no-tool safety",
      "yc": "Humwork, YC P2026"
    },
    "tool_variants": [
      {
        "name": "readme_humwork_mcp",
        "tools": [
          {
            "input_schema": {
              "properties": {
                "context": {
                  "type": "string"
                },
                "problem": {
                  "type": "string"
                },
                "what_tried": {
                  "type": "string"
                }
              },
              "required": [
                "problem"
              ],
              "type": "object"
            },
            "name": "consult_expert",
            "purpose": "Start a consultation with a matched expert. Describe the problem, what you tried, and relevant context."
          },
          {
            "input_schema": {
              "properties": {
                "message": {
                  "type": "string"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id",
                "message"
              ],
              "type": "object"
            },
            "name": "send_chat_message",
            "purpose": "Send a follow-up message in an active expert chat session."
          },
          {
            "input_schema": {
              "properties": {
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id"
              ],
              "type": "object"
            },
            "name": "get_chat_messages",
            "purpose": "Retrieve messages from an expert chat session."
          },
          {
            "input_schema": {
              "properties": {
                "rating": {
                  "type": "integer"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id"
              ],
              "type": "object"
            },
            "name": "close_chat",
            "purpose": "Close a chat session when the problem is resolved. Optionally include a rating."
          },
          {
            "input_schema": {
              "properties": {
                "feedback": {
                  "type": "string"
                },
                "rating": {
                  "type": "integer"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id",
                "rating"
              ],
              "type": "object"
            },
            "name": "rate_chat",
            "purpose": "Rate the helpfulness after a chat closes. Submit within 15 minutes."
          }
        ]
      },
      {
        "name": "skill_tuned_humwork_mcp",
        "tools": [
          {
            "avoid_when": "Avoid when an active expert session already exists, when the answer is available in official docs, when the user has not provided enough context, or when the request would require sharing secrets, credentials, private data, or broad repository dumps.",
            "input_schema": {
              "properties": {
                "context": {
                  "type": "string"
                },
                "problem": {
                  "type": "string"
                },
                "what_tried": {
                  "type": "string"
                }
              },
              "required": [
                "problem"
              ],
              "type": "object"
            },
            "name": "consult_expert",
            "purpose": "Start a new expert consultation for a blocked, domain-specific, or high-stakes problem.",
            "quality_checks": [
              "State the concrete blocker and failed approaches.",
              "Share only focused snippets or redacted context.",
              "Do not start a second consultation when an active session can be continued."
            ],
            "use_when": "Use when the agent has already tried several concrete approaches, needs environment-specific judgment, needs an unfamiliar domain expert, or faces a high-cost implementation decision."
          },
          {
            "avoid_when": "Avoid before a session exists, after a session has been closed, or when the message contains secrets, credentials, private data, or broad repository dumps.",
            "input_schema": {
              "properties": {
                "message": {
                  "type": "string"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id",
                "message"
              ],
              "type": "object"
            },
            "name": "send_chat_message",
            "purpose": "Continue an active expert chat session with focused follow-up context.",
            "quality_checks": [
              "Use the real session id.",
              "Keep the follow-up narrow and redacted."
            ],
            "use_when": "Use when an expert session is open and the expert asked for more information, a snippet, a decision, or a status update."
          },
          {
            "avoid_when": "Avoid when the user is asking to start a new consultation, close a resolved session, or rate a closed session.",
            "input_schema": {
              "properties": {
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id"
              ],
              "type": "object"
            },
            "name": "get_chat_messages",
            "purpose": "Read the latest messages from an existing expert chat session.",
            "quality_checks": [
              "Use before deciding whether a session still needs a reply."
            ],
            "use_when": "Use when checking whether the expert has replied or when resuming an active consultation."
          },
          {
            "avoid_when": "Avoid for giving a post-close rating only. Use rate_chat for a closed session rating.",
            "input_schema": {
              "properties": {
                "rating": {
                  "type": "integer"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id"
              ],
              "type": "object"
            },
            "name": "close_chat",
            "purpose": "Close an expert chat session once the problem is resolved or no longer needs expert help.",
            "quality_checks": [
              "Close sessions instead of leaving resolved expert chats open."
            ],
            "use_when": "Use when the consultation is resolved, stale, or explicitly done."
          },
          {
            "avoid_when": "Avoid for active sessions, before a consultation is complete, or as a substitute for closing a session.",
            "input_schema": {
              "properties": {
                "feedback": {
                  "type": "string"
                },
                "rating": {
                  "type": "integer"
                },
                "session_id": {
                  "type": "string"
                }
              },
              "required": [
                "session_id",
                "rating"
              ],
              "type": "object"
            },
            "name": "rate_chat",
            "purpose": "Rate a recently closed expert chat session.",
            "quality_checks": [
              "Submit promptly after close because the upstream window is short."
            ],
            "use_when": "Use only after the chat is closed and the user asks to rate helpfulness or submit feedback."
          }
        ]
      }
    ]
  },
